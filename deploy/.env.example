# --------------------------------------------------------------------------- #
# Aivory — production environment for the Docker Compose stack              #
# --------------------------------------------------------------------------- #
# Copy this file:                                                             #
#   cp .env.example .env                                                      #
# Then fill in every value marked REQUIRED.                                   #
# Provider API keys (Anthropic / OpenAI / Gemini …) are NOT here — they live  #
# in the `channels` table and are configured from the admin UI after boot.    #
# --------------------------------------------------------------------------- #

# ============ Image registry =================================================
# Where to pull the prebuilt images from. Defaults to the upstream repo's
# GHCR namespace; override if you forked into your own account.
# Used by both `api` and `web` services: image: ghcr.io/${IMAGE_OWNER}/...
IMAGE_OWNER=hjxwz123
IMAGE_TAG=latest

# ============ Network ========================================================
# The single `app` container serves the SPA + /api on one origin. No domain or
# CORS config is needed — whatever host(name) the container is reached on works,
# so multiple domains "just work". Put a TLS terminator (Caddy / Traefik / cloud
# LB) in front for HTTPS; any reverse proxy forwards the Host header by default.
#
# The host port is set in docker-compose.prod.yml (defaults to 80:8787) — edit it
# there if port 80 is taken. There is no WEB_PORT / PUBLIC_ORIGIN to configure.
#
# ALLOWED_ORIGINS is only relevant if you split the frontend onto a DIFFERENT
# origin than the API (not this single-container setup); leave it unset.
# ALLOWED_ORIGINS=

# ============ Postgres (REQUIRED password) ===================================
POSTGRES_USER=aivory
POSTGRES_DB=aivory
# REQUIRED — generate with: openssl rand -hex 24
POSTGRES_PASSWORD=change-me-strong-db-password

# ============ Redis (REQUIRED password) ======================================
# REQUIRED — generate with: openssl rand -hex 24
REDIS_PASSWORD=change-me-strong-redis-password

# ============ Qdrant (enabled by default) ====================================
# Docker Compose starts the bundled qdrant service and the app uses it by
# default. Override QDRANT_URL only when pointing at an external Qdrant cluster.
QDRANT_URL=http://qdrant:6333
# Leave QDRANT_API_KEY blank to use the built-in shared default (qdrant + api
# both fall back to the same internal key, so it works out of the box; Qdrant has
# no public port). Set a strong value (openssl rand -hex 24) to override it.
QDRANT_API_KEY=

# ============ Auth (REQUIRED) ================================================
# Long random secret. Aivory REFUSES to boot in production with the dev
# default. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# ============ First-run admin ================================================
# No admin is seeded from the environment. On first launch the deployment has
# zero users — open the site and the FIRST account you create (name + email +
# password) becomes the administrator. Manage users from /admin afterwards.

# ============ Data directory (uploads + artifacts) ===========================
# Host path bind-mounted into the api container at /app/data, holding user
# uploads and generated artifacts (and the SQLite file if you ever use it).
# Defaults to ./data next to this compose file — back this directory up.
DATA_DIR=./data
# Container path for async admin full-backup archives. The default lives under
# DATA_DIR on the host (./data/backups), but is not folded into uploads/artifacts
# during export, avoiding recursive backup ZIPs.
BACKUP_DIR=/app/data/backups
# Max size accepted by admin backup import. Full archives with Qdrant vectors can
# be large; default is 20 GiB.
MAX_BACKUP_BYTES=21474836480

# Seed a mock channel so the install is testable end-to-end without keys.
# Set to false once you've added a real provider channel in /admin.
ENABLE_MOCK_PROVIDER=false

# ============ web_search (optional, §4.4) ====================================
# Most of this is also configurable live from the admin UI; values here are
# only the boot-time fallback.
#   serper / brave  → set SEARCH_API_KEY
#   searxng         → set SEARCH_BASE_URL (no key needed)
SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_BASE_URL=

# ============ Embedding (optional, §4.11-D) ==================================
# Unset → the bundled local hash-bag embedder is used (256-dim, OK for dev,
# not great for production retrieval). For real RAG point this at any
# OpenAI-format /v1/embeddings endpoint and add a matching model in /admin.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ============ MinerU document parsing (optional, §4.11-C) ====================
# Required for OCR'd / scanned / image-heavy documents. Without it those
# uploads still land in the KB but only show a placeholder line.
# Also configurable live from the admin Settings page.
MINERU_API_URL=https://mineru.net
MINERU_API_KEY=

# ============ Sandbox (bundled — usually nothing to set) =====================
# The `sandbox` service ships inside this stack and is reached by the API over
# the private network only (never published to a host port). The API and the
# sandbox already share a default internal key, so code execution works out of
# the box — leave these blank.
# It needs the host Docker socket (already mounted in the compose file) to spawn
# per-session containers, and pulls ghcr.io/${IMAGE_OWNER}/aivory-sandbox on
# boot. Keep the admin Settings sandbox_base_url / sandbox_api_key fields BLANK
# so the bundled service is used.
# Override only if you want a non-default key or bigger per-session limits:
# SANDBOX_API_KEY=
# SANDBOX_MEMORY=2g
# SANDBOX_CPUS=1
# SANDBOX_MAX_SESSIONS=16
# SANDBOX_WORKSPACE_SIZE=512m
# SANDBOX_MAX_UPLOAD_BYTES=41943040   # 40 MiB decoded file
# SANDBOX_MAX_BODY_BYTES=58720256     # 56 MiB for base64 + JSON overhead
