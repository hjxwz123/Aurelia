# --------------------------------------------------------------------------- #
# Auven — environment variables                                              #
# --------------------------------------------------------------------------- #
# Every value below has a sensible default — Auven boots clean without any  #
# of them. Provider API keys (Anthropic/OpenAI/Gemini) are NOT here; they live #
# in the `channels` table and are configured via the admin UI per §2.3-B.     #
# --------------------------------------------------------------------------- #

# ---------- Server ----------
AUVEN_LISTEN=:8787
AUVEN_ENV=development

# ---------- Storage ----------
# SQLite by default. Same schema ports cleanly to Postgres — see
# server/internal/store/schema.sql. To swap drivers, change Open() in
# server/internal/store/store.go.
DATABASE_URL=./data/auven.db?_pragma=journal_mode(WAL)&_pragma=busy_timeout(5000)
UPLOAD_DIR=./data/uploads
ARTIFACT_DIR=./data/artifacts
MAX_UPLOAD_BYTES=50000000   # 50 MB

# ---------- Auth (§8.1) ----------
# CHANGE JWT_SECRET in production to a long random string. Token version
# bumping via SetUserStatus revokes outstanding access tokens immediately.
JWT_SECRET=change-me-to-a-long-random-secret-please
ACCESS_TTL=2h
REFRESH_TTL=720h    # 30 days
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- Quotas (per user per day, §8) ----------
DAILY_MESSAGE_LIMIT=200
IMAGE_DAILY_LIMIT=30

# ---------- First-boot admin ----------
# Only used when the database has no admin users yet.
SEED_ADMIN_EMAIL=admin@auven.local
SEED_ADMIN_PASSWORD=auven-admin

# Seed the mock channel + Auven Mock chat model so a fresh DB is usable.
# Set to false in production once you've added real channels.
ENABLE_MOCK_PROVIDER=true

# ---------- web_search (§4.4) ----------
# Without these, the web_search tool returns a polite placeholder so the
# model can still answer. Set both to enable the real Serper backend.
SEARCH_PROVIDER=serper
SEARCH_API_KEY=

# ---------- Real embedding (§4.11-D) ----------
# Unset → use the bundled local hash-bag embedder (256-dim). Knowledge bases
# still work for development; switch to a real OpenAI-format embedder for
# production. Configure them in /admin/models with kind=embedding too.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---------- Document parsing (§4.11-C, optional) ----------
# MinerU is used for scanned PDFs and image-heavy documents. Unset → all
# documents go through the local text-only parser.
MINERU_API_URL=
MINERU_API_KEY=

# ---------- Sandbox (§4.5, optional) ----------
# If set, python_execute will proxy calls to your sandbox service. Otherwise
# it runs in safe-mode (arithmetic-only). The interface is in
# server/internal/tools/builtins.go::pythonExecuteTool.
SANDBOX_BASE_URL=
SANDBOX_API_KEY=

# --------------------------------------------------------------------------- #
# Frontend (Vite) — leave these blank unless you're running the dev server   #
# against a non-default backend                                              #
# --------------------------------------------------------------------------- #
# VITE_API_BASE=/api
# VITE_API_TARGET=http://localhost:8787
